// Managed by catppuccin-mode.
// This intentionally replaces DMS/matugen colors so niri follows Catppuccin.

layout {
    background-color "transparent"

    focus-ring {
        active-color   "#8839ef"
        inactive-color "#00000000"
        urgent-color   "#d20f39"
    }

    border {
        active-color   "#00000000"
        inactive-color "#00000000"
        urgent-color   "#d20f39"
    }

    shadow {
        color "#00000045"
    }

    tab-indicator {
        active-color   "#8839ef"
        inactive-color "#9ca0b0"
        urgent-color   "#d20f39"
    }

    insert-hint {
        color "#8839ef80"
    }
}

recent-windows {
    highlight {
        active-color "#7287fd"
        urgent-color "#d20f39"
    }
}
